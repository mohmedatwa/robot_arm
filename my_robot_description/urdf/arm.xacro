<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.098 0.098 0.05087" />
            </geometry>
            <origin xyz="0 0 0.025435" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="0.098 0.098 0.05087" />
            </geometry>
            <origin xyz="0 0 0.025435" rpy="0 0 0" />
        </collision>
    </link>

    <link name="shoulder_link">
        <visual>
            <geometry>
                <cylinder length="0.04601" radius="0.044" />
            </geometry>
            <origin xyz="0 0 0.023005" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.04601" radius="0.044" />
            </geometry>
            <origin xyz="0 0 0.023005" rpy="0 0 0" />
        </collision>
    </link>

    <link name="arm_link">
        <visual>
            <geometry>
                <cylinder length="0.11312" radius="0.013" />
            </geometry>
            <origin xyz="0 0 0.05656" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="0.026 0.026 0.11312" />
            </geometry>
            <origin xyz="0 0 0.05656" rpy="0 0 0" />
        </collision>
    </link>

    <link name="elbow_link">
        <visual>
            <geometry>
                <cylinder length="0.09795" radius="0.010885" />
            </geometry>
            <origin xyz="0 0 0.048975" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="0.02177 0.02177 0.09795" />
            </geometry>
            <origin xyz="0 0 0.048975" rpy="0 0 0" />
        </collision>
    </link>

    <link name="forearm_link">
        <visual>
            <geometry>
                <box size="0.013 0.013 0.02908" />
            </geometry>
            <origin xyz="0 0 0.01454" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <box size="0.013 0.013 0.02908" />
            </geometry>
            <origin xyz="0 0 0.01454" rpy="0 0 0" />
        </collision>
    </link>

    <link name="wrist_link">
        <visual>
            <geometry>
                <box size="0.02177 0.02177 0.01999" />
            </geometry>
            <origin xyz="0 0 0.009995" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="0.02177 0.02177 0.01099" />
            </geometry>
            <origin xyz="0 0 0.009995" rpy="0 0 0" />
        </collision>
    </link>


    <link name="tool_link" />

    <joint name="joint1" type="revolute">
        <parent link="base_link" />
        <child link="shoulder_link" />
        <origin xyz="0 0 0.05087" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="1.0" lower="-1.57" upper="1.57" />
    </joint>

    <joint name="joint2" type="revolute">
        <parent link="shoulder_link" />
        <child link="arm_link" />
        <origin xyz="0 0 0.04601" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="-1.57" upper="1.57" />
    </joint>

    <joint name="joint3" type="revolute">
        <parent link="arm_link" />
        <child link="elbow_link" />
        <origin xyz="0 0 0.11312" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="-1.57" upper="1.57" />
    </joint>

    <joint name="joint4" type="revolute">
        <parent link="elbow_link" />
        <child link="forearm_link" />
        <origin xyz="0 0 0.09795" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit effort="1000.0" velocity="1.0" lower="-1.57" upper="1.57" />
    </joint>

    <joint name="joint5" type="revolute">
        <parent link="forearm_link" />
        <child link="wrist_link" />
        <origin xyz="0 0 0.02908" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="-1.57" upper="1.57" />
    </joint>

 

    <joint name="hand_tool_joint" type="fixed">
        <parent link="wrist_link" />
        <child link="tool_link" />
        <origin xyz="0 0 0.009995" rpy="0 0 0" />
    </joint>

</robot>