<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_robot">

    <xacro:arg name="use_mock_hardware" default="true"/>
    <xacro:arg name="serial_port" default="/dev/ttyUSB0"/>
    <xacro:arg name="baud_rate" default="115200"/>
    <xacro:arg name="initial_positions_file"
               default="$(find my_robot_moveit_config)/config/initial_positions.yaml"/>

    <xacro:include filename="$(find my_robot_description)/urdf/my_robot.urdf.xacro" />

</robot>
