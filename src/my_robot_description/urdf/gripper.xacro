<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="gripper_base_link">
        <visual>
            <geometry>
                <box size="0.1 0.03 0.02" />
            </geometry>
            <origin xyz="0 0 0.01" rpy="0 0 1.57" />
            <material name="dark_green" />
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.03 0.02" />
            </geometry>
            <origin xyz="0 0 0.01" rpy="0 0 1.57" />
        </collision>
    </link>

    <link name="gripper_left_finger_link">
        <visual>
            <geometry>
                <box size="0.01 0.03 0.04" />
            </geometry>
            <origin xyz="0 0 0.02" rpy="0 0 1.57" />
            <material name="light_green" />
        </visual>
        <collision>
            <geometry>
                <box size="0.01 0.03 0.04" />
            </geometry>
            <origin xyz="0 0 0.02" rpy="0 0 1.57" />
        </collision>
    </link>

    <link name="gripper_right_finger_link">
        <visual>
            <geometry>
                <box size="0.01 0.03 0.04" />
            </geometry>
            <origin xyz="0 0 0.02" rpy="0 0 1.57" />
            <material name="light_green" />
        </visual>
        <collision>
            <geometry>
                <box size="0.01 0.03 0.04" />
            </geometry>
            <origin xyz="0 0 0.02" rpy="0 0 1.57" />
        </collision>
    </link>

    <joint name="gripper_left_finger_joint" type="prismatic">
        <parent link="gripper_base_link" />
        <child link="gripper_left_finger_link" />
        <origin xyz="0 -0.04 0.02" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit effort="1000.0" velocity="1.0" lower="0.0" upper="0.035" />
    </joint>

    <joint name="gripper_right_finger_joint" type="prismatic">
        <parent link="gripper_base_link" />
        <child link="gripper_right_finger_link" />
        <origin xyz="0 0.04 0.02" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <mimic joint="gripper_left_finger_joint" multiplier="-1.0" />
        <limit effort="1000.0" velocity="1.0" lower="-0.035" upper="0.0" />
    </joint>

</robot>